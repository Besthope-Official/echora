{
  "name": "echora",
  "displayName": "Echora",
  "description": "Echora is a VS Code extension that empowers your CLI agent with STT/TTS and makes it your best companion — chatting, learning, and working, always echoing to you.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "Besthope",
  "categories": [
    "AI",
    "Chat",
    "Education",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "icons": {
      "echora-status": {
        "description": "Echora status icon",
        "default": {
          "fontPath": "./media/font/fonts/echora.woff",
          "fontCharacter": "\\F000"
        }
      }
    },
    "commands": [
      {
        "command": "echora.startDictation",
        "title": "Echora: Start Dictation (Manual)"
      },
      {
        "command": "echora.stopDictation",
        "title": "Echora: Stop Dictation (Manual)"
      },
      {
        "command": "echora.startVoicePipeline",
        "title": "Echora: Start Voice Pipeline"
      },
      {
        "command": "echora.stopVoicePipeline",
        "title": "Echora: Stop Voice Pipeline"
      }
    ],
    "configuration": {
      "title": "Echora",
      "properties": {
        "echora.nodeSpeech.locale": {
          "type": "string",
          "default": "auto",
          "description": "Preferred locale for voice input recognition. Use 'auto' to follow VS Code UI language, or set e.g. 'zh-CN', 'en-US'."
        },
        "echora.stt.sessionDurationMs": {
          "type": "number",
          "default": 20000,
          "minimum": 0,
          "description": "Maximum duration (ms) for a voice input session. Set to 0 to disable auto-stop (future VAD mode). Default: 20000."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "clean-tests-out": "node -e \"require('fs').rmSync('out/test', { recursive: true, force: true })\"",
    "compile-tests": "pnpm run clean-tests-out && tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}
